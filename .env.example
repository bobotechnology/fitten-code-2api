# Copy this file to .env and fill in your Fitten credentials before starting the server.
# The server uses dotenv to load .env automatically.

PORT=3000
FITTEN_BASE_URL=https://fc.fittenlab.cn
DEFAULT_MODEL=fitten-code
FITTEN_USER_AGENT=
FITTEN_REQUEST_TIMEOUT_MS=120000
FITTEN_ACCESS_TOKEN_REFRESH_MARGIN_MS=60000
MAX_IMAGE_BYTES=5242880

FITTEN_USERNAME=
FITTEN_PASSWORD=
